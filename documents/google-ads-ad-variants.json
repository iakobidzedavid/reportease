  "copy_quality_guidelines": {
    "headlines": [
      "Lead with primary benefit (time, accuracy, or visibility)",
      "Keep under 30 characters strictly",
      "Action-oriented language preferred",
      "Avoid ALL CAPS (except acronyms like 'SEO')",
      "No exclamation marks (overuse)",
      "Include brand name or product name where possible"
    ],
    "descriptions": [
      "Provide specific details (e.g., 'Google Analytics, HubSpot, ad platforms')",
      "Keep under 90 characters strictly",
      "Include CTA when possible ('start', 'try', 'discover')",
      "Focus on buyer benefits, not features",
      "Avoid generic claims ('best', 'top', 'leading')",
      "Match landing page messaging for quality score boost"
    ],
    "overall": [
      "Ensure headlines + descriptions tell complete story",
      "Don't repeat same message across headlines",
      "Test variations within match type (phrase vs broad)",
      "Use numbers where credible (6 hours, 30+ minutes)",
      "Appeal to target persona pain points"
    ]
  },
  "testing_framework": {
    "test_duration_days": 30,
    "primary_metric": "Cost Per Lead (CPL)",
    "secondary_metrics": [
